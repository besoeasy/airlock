#!/usr/bin/env bash

set -e

VERSION="0.0.1"

REPO_URL="https://github.com/besoeasy/airlock"
RAW_URL="https://raw.githubusercontent.com/besoeasy/airlock/main/airlock"

declare -A IMAGES

IMAGES[debian]="debian:stable"
IMAGES[alpine]="alpine:latest"
IMAGES[node]="node:lts"
IMAGES[python]="python:3"
IMAGES[go]="golang:latest"
IMAGES[bun]="oven/bun:latest"
IMAGES[rust]="rust:latest"
IMAGES[java]="eclipse-temurin:21"
IMAGES[ubuntu]="ubuntu:24.04"
IMAGES[arch]="archlinux:latest"
IMAGES[fedora]="fedora:latest"
IMAGES[deno]="denoland/deno:latest"
IMAGES[zig]="ziglang/zig:latest"
IMAGES[nix]="nixos/nix:latest"

CONFIG_IMAGE=""
CONFIG_COMMAND=""
CONFIG_MODE="dev"

load_airlock_config() {
CONFIG_IMAGE=""
CONFIG_COMMAND=""
CONFIG_MODE="dev"

if [ ! -f .airlock ]; then
    return 1
fi

while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [ -z "$line" ] && continue
    case "$line" in
        *=*) ;;
        *) continue ;;
    esac

    key="${line%%=*}"
    value="${line#*=}"
    key="${key#"${key%%[![:space:]]*}"}"
    key="${key%"${key##*[![:space:]]}"}"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"

    case "$key" in
        image) CONFIG_IMAGE="$value" ;;
        command) CONFIG_COMMAND="$value" ;;
        mode) CONFIG_MODE="$value" ;;
    esac
done < .airlock

return 0
}

resolve_image() {
local name="$1"

if [ -n "${IMAGES[$name]:-}" ]; then
    echo "${IMAGES[$name]}"
    return
fi

if [[ "$name" == *:* || "$name" == */* ]]; then
    echo "$name"
    return
fi

echo "Unknown image: $name"
echo "Run: airlock help"
exit 1
}

banner() {
cat <<'EOF'
_    _      _            _
/ \  (*)* **| | ___   ***| | __
/ _ \ | | '**| |/ _ \ / __| |/ /
/ ___ | | |  | | (*) | (**|   <
/*/   __|*|  |*|_**/ _**|*|_\

Secure Development Sandbox
EOF
}

detect_container_runtime() {
if command -v docker >/dev/null 2>&1; then
CONTAINER_RUNTIME="docker"
return
fi

if command -v podman >/dev/null 2>&1; then
    CONTAINER_RUNTIME="podman"
    return
fi

echo
echo "Docker or Podman is required."
exit 1

}

detect_shell() {
local image="$1"

case "$image" in
    alpine:*|archlinux:*|fedora:*|nixos/*)
        echo "sh"
        ;;
    *)
        echo "bash"
        ;;
esac

}

launch_image() {
detect_container_runtime

local image="$1"
local command="${2:-}"
local mode="${3:-dev}"
local shell
local -a run_args

shell=$(detect_shell "$image")

case "$mode" in
    dev)
        run_args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
        )
        ;;
    audit)
        run_args=(
            run -it --rm
            --read-only
            --tmpfs /tmp
            --network none
            -v "$PWD:/workspace:ro"
            -w /workspace
            --user "$(id -u):$(id -g)"
        )
        ;;
    *)
        echo "Unknown mode: $mode"
        echo "Supported modes: dev, audit"
        exit 1
        ;;
esac

if [ -n "$command" ]; then
    "$CONTAINER_RUNTIME" "${run_args[@]}" "$image" "$shell" -c "$command"
else
    "$CONTAINER_RUNTIME" "${run_args[@]}" "$image" "$shell"
fi

}

launch_named() {
local name="$1"

load_airlock_config 2>/dev/null || true
launch_image "$(resolve_image "$name")" "" "${CONFIG_MODE:-dev}"
}

launch_from_config() {
load_airlock_config || {
    echo ".airlock not found."
    exit 1
}

if [ -z "$CONFIG_IMAGE" ]; then
    echo ".airlock: image is required."
    exit 1
fi

launch_image "$(resolve_image "$CONFIG_IMAGE")" "$CONFIG_COMMAND" "${CONFIG_MODE:-dev}"
}

update_airlock() {
echo "Updating Airlock..."

TMP_FILE=$(mktemp)

curl -fsSL "$RAW_URL" -o "$TMP_FILE"

chmod +x "$TMP_FILE"

if [ -w /usr/local/bin/airlock ]; then
    mv "$TMP_FILE" /usr/local/bin/airlock
else
    sudo mv "$TMP_FILE" /usr/local/bin/airlock
fi

echo "Airlock updated."

}

show_help() {
echo
echo "Repository:"
echo "$REPO_URL"
echo
echo "Usage:"
echo "  airlock"
echo "  airlock debian"
echo "  airlock alpine"
echo "  airlock node"
echo "  airlock python"
echo "  airlock go"
echo "  airlock rust"
echo "  airlock java"
echo "  airlock ubuntu"
echo "  airlock arch"
echo "  airlock fedora"
echo "  airlock deno"
echo "  airlock zig"
echo "  airlock nix"
echo
echo "Project config (.airlock):"
echo "  image=node"
echo "  command=npm test"
echo "  mode=dev"
echo
echo "Run airlock in a directory with .airlock to use project settings."
echo
}

menu() {
while true; do

clear

banner

detect_container_runtime

echo
echo "Runtime: $CONTAINER_RUNTIME"
echo

echo "1) Debian"
echo "2) Alpine"
echo "3) Node"
echo "4) Python"
echo "5) Go"
echo "6) Bun"
echo "7) Rust"
echo "8) Java"
echo "9) Ubuntu"
echo "10) Arch"
echo "11) Fedora"
echo "12) Deno"
echo "13) Zig"
echo "14) Nix"
echo "15) Update"
echo "16) Help"
echo "17) Version"
echo "18) Exit"
echo

read -rp "Select option: " choice

case "$choice" in
1) launch_image "${IMAGES[debian]}" ;;
2) launch_image "${IMAGES[alpine]}" ;;
3) launch_image "${IMAGES[node]}" ;;
4) launch_image "${IMAGES[python]}" ;;
5) launch_image "${IMAGES[go]}" ;;
6) launch_image "${IMAGES[bun]}" ;;
7) launch_image "${IMAGES[rust]}" ;;
8) launch_image "${IMAGES[java]}" ;;
9) launch_image "${IMAGES[ubuntu]}" ;;
10) launch_image "${IMAGES[arch]}" ;;
11) launch_image "${IMAGES[fedora]}" ;;
12) launch_image "${IMAGES[deno]}" ;;
13) launch_image "${IMAGES[zig]}" ;;
14) launch_image "${IMAGES[nix]}" ;;
15) update_airlock ;;
16) show_help ;;
17) echo "$VERSION" ;;
18) exit 0 ;;
esac

done
}

case "${1:-}" in
"")
if [ -f .airlock ]; then
    launch_from_config
else
    menu
fi
;;
update)
update_airlock
;;
help)
show_help
;;
version)
echo "$VERSION"
;;
debian)
launch_named debian
;;
alpine)
launch_named alpine
;;
node)
launch_named node
;;
python)
launch_named python
;;
go)
launch_named go
;;
bun)
launch_named bun
;;
rust)
launch_named rust
;;
java)
launch_named java
;;
ubuntu)
launch_named ubuntu
;;
arch)
launch_named arch
;;
fedora)
launch_named fedora
;;
deno)
launch_named deno
;;
zig)
launch_named zig
;;
nix)
launch_named nix
;;
*)
echo "Unknown command."
echo "Run: airlock help"
exit 1
;;
esac
