#!/usr/bin/env bash
set -e

VERSION="0.1.0"
REPO_URL="https://github.com/besoeasy/airlock"
RAW_URL="https://raw.githubusercontent.com/besoeasy/airlock/main/airlock"

banner() {
cat <<EOF
    _    _      _            _
   / \  (_)_ __| | ___   ___| | __
  / _ \ | | '__| |/ _ \ / __| |/ /
 / ___ \| | |  | | (_) | (__|   <
/_/   \_\_|_|  |_|\___/ \___|_|\_\

Secure Dependency Sandbox
EOF
}

detect_container_runtime() {
    if command -v docker >/dev/null 2>&1; then
        CONTAINER_RUNTIME="docker"
        return
    fi

    if command -v podman >/dev/null 2>&1; then
        CONTAINER_RUNTIME="podman"
        return
    fi

    echo "Neither Docker nor Podman is installed."
    exit 1
}

container_shell() {
    detect_container_runtime
    "$CONTAINER_RUNTIME" run -it --rm \
        -v "$PWD:/workspace" \
        -w /workspace \
        --user "$(id -u):$(id -g)" \
        docker.io/library/node:lts bash
}

run_node() {
    detect_container_runtime
    "$CONTAINER_RUNTIME" run -it --rm \
        -v "$PWD:/workspace" \
        -w /workspace \
        --user "$(id -u):$(id -g)" \
        docker.io/library/node:lts bash -c "$*"
}

update_airlock() {
    TMP_FILE=$(mktemp)
    curl -fsSL "$RAW_URL" -o "$TMP_FILE"
    chmod +x "$TMP_FILE"

    if [ -w /usr/local/bin/airlock ]; then
        mv "$TMP_FILE" /usr/local/bin/airlock
    else
        sudo mv "$TMP_FILE" /usr/local/bin/airlock
    fi

    echo "Airlock updated."
}

help_airlock() {
    echo "Repository: $REPO_URL"
}

menu() {
while true; do
    clear
    banner
    detect_container_runtime
    echo
    echo "Runtime: $CONTAINER_RUNTIME"
    echo
    echo "1) npm install"
    echo "2) pnpm install"
    echo "3) yarn install"
    echo "4) bun install"
    echo "5) shell"
    echo "6) update"
    echo "7) help"
    echo "8) version"
    echo "9) exit"
    read -rp "Select option: " choice

    case "$choice" in
        1) run_node "npm install" ;;
        2) run_node "npm install -g pnpm && pnpm install" ;;
        3) run_node "npm install -g yarn && yarn install" ;;
        4) run_node "npm install -g bun && bun install" ;;
        5) container_shell ;;
        6) update_airlock ;;
        7) help_airlock ;;
        8) echo "$VERSION" ;;
        9) exit 0 ;;
    esac
done
}

case "${1:-}" in
    "") menu ;;
    update) update_airlock ;;
    help) help_airlock ;;
    version) echo "$VERSION" ;;
    shell) container_shell ;;
    npm) shift; run_node "npm $*" ;;
    pnpm) shift; run_node "npm install -g pnpm && pnpm $*" ;;
    yarn) shift; run_node "npm install -g yarn && yarn $*" ;;
    bun) shift; run_node "npm install -g bun && bun $*" ;;
    *) echo "Unknown command"; exit 1 ;;
esac
