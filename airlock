#!/usr/bin/env bash

set -e

VERSION="0.0.1"

REPO_URL="https://github.com/besoeasy/airlock"
RAW_URL="https://raw.githubusercontent.com/besoeasy/airlock/main/airlock"

declare -A IMAGES

IMAGES[debian]="debian:stable"
IMAGES[alpine]="alpine:latest"
IMAGES[node]="node:lts"
IMAGES[python]="python:3"
IMAGES[go]="golang:latest"
IMAGES[bun]="oven/bun:latest"
IMAGES[rust]="rust:latest"
IMAGES[java]="eclipse-temurin:21"
IMAGES[ubuntu]="ubuntu:24.04"
IMAGES[arch]="archlinux:latest"
IMAGES[fedora]="fedora:latest"
IMAGES[deno]="denoland/deno:latest"
IMAGES[zig]="ziglang/zig:latest"
IMAGES[nix]="nixos/nix:latest"

banner() {
cat <<'EOF'
_    _      _            _
/ \  (*)* **| | ___   ***| | __
/ _ \ | | '**| |/ _ \ / __| |/ /
/ ___ | | |  | | (*) | (**|   <
/*/   __|*|  |*|_**/ _**|*|_\

Secure Development Sandbox
EOF
}

detect_container_runtime() {
if command -v docker >/dev/null 2>&1; then
CONTAINER_RUNTIME="docker"
return
fi

```
if command -v podman >/dev/null 2>&1; then
    CONTAINER_RUNTIME="podman"
    return
fi

echo
echo "Docker or Podman is required."
exit 1
```

}

detect_shell() {
local image="$1"

```
case "$image" in
    alpine:*|archlinux:*|fedora:*|nixos/*)
        echo "sh"
        ;;
    *)
        echo "bash"
        ;;
esac
```

}

launch_image() {
detect_container_runtime

```
local image="$1"
local shell

shell=$(detect_shell "$image")

"$CONTAINER_RUNTIME" run -it --rm \
    -v "$PWD:/workspace" \
    -w /workspace \
    --user "$(id -u):$(id -g)" \
    "$image" \
    "$shell"
```

}

update_airlock() {
echo "Updating Airlock..."

```
TMP_FILE=$(mktemp)

curl -fsSL "$RAW_URL" -o "$TMP_FILE"

chmod +x "$TMP_FILE"

if [ -w /usr/local/bin/airlock ]; then
    mv "$TMP_FILE" /usr/local/bin/airlock
else
    sudo mv "$TMP_FILE" /usr/local/bin/airlock
fi

echo "Airlock updated."
```

}

show_help() {
echo
echo "Repository:"
echo "$REPO_URL"
echo
echo "Usage:"
echo "  airlock"
echo "  airlock debian"
echo "  airlock alpine"
echo "  airlock node"
echo "  airlock python"
echo "  airlock go"
echo "  airlock rust"
echo "  airlock java"
echo "  airlock ubuntu"
echo "  airlock arch"
echo "  airlock fedora"
echo "  airlock deno"
echo "  airlock zig"
echo "  airlock nix"
echo
}

menu() {
while true; do

clear

banner

detect_container_runtime

echo
echo "Runtime: $CONTAINER_RUNTIME"
echo

echo "1) Debian"
echo "2) Alpine"
echo "3) Node"
echo "4) Python"
echo "5) Go"
echo "6) Bun"
echo "7) Rust"
echo "8) Java"
echo "9) Ubuntu"
echo "10) Arch"
echo "11) Fedora"
echo "12) Deno"
echo "13) Zig"
echo "14) Nix"
echo "15) Update"
echo "16) Help"
echo "17) Version"
echo "18) Exit"
echo

read -rp "Select option: " choice

case "$choice" in
1) launch_image "${IMAGES[debian]}" ;;
2) launch_image "${IMAGES[alpine]}" ;;
3) launch_image "${IMAGES[node]}" ;;
4) launch_image "${IMAGES[python]}" ;;
5) launch_image "${IMAGES[go]}" ;;
6) launch_image "${IMAGES[bun]}" ;;
7) launch_image "${IMAGES[rust]}" ;;
8) launch_image "${IMAGES[java]}" ;;
9) launch_image "${IMAGES[ubuntu]}" ;;
10) launch_image "${IMAGES[arch]}" ;;
11) launch_image "${IMAGES[fedora]}" ;;
12) launch_image "${IMAGES[deno]}" ;;
13) launch_image "${IMAGES[zig]}" ;;
14) launch_image "${IMAGES[nix]}" ;;
15) update_airlock ;;
16) show_help ;;
17) echo "$VERSION" ;;
18) exit 0 ;;
esac

done
}

case "${1:-}" in
"")
menu
;;
update)
update_airlock
;;
help)
show_help
;;
version)
echo "$VERSION"
;;
debian)
launch_image "${IMAGES[debian]}"
;;
alpine)
launch_image "${IMAGES[alpine]}"
;;
node)
launch_image "${IMAGES[node]}"
;;
python)
launch_image "${IMAGES[python]}"
;;
go)
launch_image "${IMAGES[go]}"
;;
bun)
launch_image "${IMAGES[bun]}"
;;
rust)
launch_image "${IMAGES[rust]}"
;;
java)
launch_image "${IMAGES[java]}"
;;
ubuntu)
launch_image "${IMAGES[ubuntu]}"
;;
arch)
launch_image "${IMAGES[arch]}"
;;
fedora)
launch_image "${IMAGES[fedora]}"
;;
deno)
launch_image "${IMAGES[deno]}"
;;
zig)
launch_image "${IMAGES[zig]}"
;;
nix)
launch_image "${IMAGES[nix]}"
;;
*)
echo "Unknown command."
echo "Run: airlock help"
exit 1
;;
esac
