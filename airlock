#!/usr/bin/env bash

set -e

VERSION="0.0.1"

REPO_URL="https://github.com/besoeasy/airlock"
RAW_URL="https://raw.githubusercontent.com/besoeasy/airlock/main/airlock"

declare -A IMAGES

IMAGES[debian]="debian:stable"
IMAGES[alpine]="alpine:latest"
IMAGES[node]="node:lts"
IMAGES[python]="python:3"
IMAGES[go]="golang:latest"
IMAGES[bun]="oven/bun:latest"
IMAGES[rust]="rust:latest"
IMAGES[java]="eclipse-temurin:21"
IMAGES[ubuntu]="ubuntu:24.04"
IMAGES[arch]="archlinux:latest"
IMAGES[fedora]="fedora:latest"
IMAGES[deno]="denoland/deno:latest"
IMAGES[zig]="ziglang/zig:latest"
IMAGES[nix]="nixos/nix:latest"

CONFIG_IMAGE=""
CONFIG_COMMAND=""

load_airlock_config() {
CONFIG_IMAGE=""
CONFIG_COMMAND=""

if [ ! -f .airlock ]; then
    return 1
fi

while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [ -z "$line" ] && continue
    case "$line" in
        *=*) ;;
        *) continue ;;
    esac

    key="${line%%=*}"
    value="${line#*=}"
    key="${key#"${key%%[![:space:]]*}"}"
    key="${key%"${key##*[![:space:]]}"}"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"

    case "$key" in
        image) CONFIG_IMAGE="$value" ;;
        command) CONFIG_COMMAND="$value" ;;
    esac
done < .airlock

return 0
}

resolve_image_ref() {
local spec="$1"

if [ -n "${IMAGES[$spec]:-}" ]; then
    echo "${IMAGES[$spec]}"
    return
fi

if [[ "$spec" == *:* || "$spec" == */* ]]; then
    echo "$spec"
    return
fi

echo "Unknown image: $spec"
echo "Run: airlock help"
exit 1
}

resolve_profile() {
local spec="$1"
local key

if [ -n "${IMAGES[$spec]:-}" ]; then
    echo "$spec"
    return
fi

for key in "${!IMAGES[@]}"; do
    if [ "${IMAGES[$key]}" = "$spec" ]; then
        echo "$key"
        return
    fi
done

echo "generic"
}

image_shell() {
case "$1" in
    alpine|nix)
        echo "sh"
        ;;
    *)
        echo "bash"
        ;;
esac
}

image_run_args() {
local profile="$1"
local -n args="$2"

case "$profile" in
    debian|ubuntu|fedora|arch)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
        )
        ;;
    alpine)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
        )
        ;;
    node)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e npm_config_cache=/workspace/.npm-cache
            -e NODE_ENV=development
        )
        ;;
    python)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e PIP_CACHE_DIR=/workspace/.pip-cache
            -e PYTHONDONTWRITEBYTECODE=1
        )
        ;;
    go)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e GOMODCACHE=/workspace/.gomodcache
            -e GOCACHE=/workspace/.gocache
        )
        ;;
    bun)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e BUN_INSTALL_CACHE_DIR=/workspace/.bun-cache
        )
        ;;
    rust)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e CARGO_HOME=/workspace/.cargo
            -e CARGO_TARGET_DIR=/workspace/target
        )
        ;;
    java)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e JAVA_TOOL_OPTIONS=-Duser.home=/workspace
        )
        ;;
    deno)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e DENO_DIR=/workspace/.deno
        )
        ;;
    zig)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e XDG_CACHE_HOME=/workspace/.cache
        )
        ;;
    nix)
        args=(
            run -it --rm
            --security-opt seccomp=unconfined
            -v "$PWD:/workspace"
            -w /workspace
            -e 'NIX_CONFIG=experimental-features = nix-command flakes'
        )
        ;;
    *)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
        )
        ;;
esac
}

banner() {
cat <<'EOF'
_    _      _            _
/ \  (*)* **| | ___   ***| | __
/ _ \ | | '**| |/ _ \ / __| |/ /
/ ___ | | |  | | (*) | (**|   <
/*/   __|*|  |*|_**/ _**|*|_\

Secure Development Sandbox
EOF
}

detect_container_runtime() {
if command -v docker >/dev/null 2>&1; then
CONTAINER_RUNTIME="docker"
return
fi

if command -v podman >/dev/null 2>&1; then
    CONTAINER_RUNTIME="podman"
    return
fi

echo
echo "Docker or Podman is required."
exit 1

}

launch_image() {
detect_container_runtime

local profile="$1"
local image="$2"
local command="${3:-}"
local shell
local -a run_args

shell=$(image_shell "$profile")
image_run_args "$profile" run_args

if [ -n "$command" ]; then
    "$CONTAINER_RUNTIME" "${run_args[@]}" "$image" "$shell" -c "$command"
else
    "$CONTAINER_RUNTIME" "${run_args[@]}" "$image" "$shell"
fi

}

launch_named() {
local name="$1"

launch_image "$name" "${IMAGES[$name]}"
}

launch_from_config() {
local profile image

load_airlock_config || {
    echo ".airlock not found."
    exit 1
}

if [ -z "$CONFIG_IMAGE" ]; then
    echo ".airlock: image is required."
    exit 1
fi

image=$(resolve_image_ref "$CONFIG_IMAGE")
profile=$(resolve_profile "$CONFIG_IMAGE")
launch_image "$profile" "$image" "$CONFIG_COMMAND"
}

update_airlock() {
echo "Updating Airlock..."

TMP_FILE=$(mktemp)

curl -fsSL "$RAW_URL" -o "$TMP_FILE"

chmod +x "$TMP_FILE"

if [ -w /usr/local/bin/airlock ]; then
    mv "$TMP_FILE" /usr/local/bin/airlock
else
    sudo mv "$TMP_FILE" /usr/local/bin/airlock
fi

echo "Airlock updated."

}

show_help() {
echo
echo "Repository:"
echo "$REPO_URL"
echo
echo "Usage:"
echo "  airlock"
echo "  airlock debian"
echo "  airlock alpine"
echo "  airlock node"
echo "  airlock python"
echo "  airlock go"
echo "  airlock rust"
echo "  airlock java"
echo "  airlock ubuntu"
echo "  airlock arch"
echo "  airlock fedora"
echo "  airlock deno"
echo "  airlock zig"
echo "  airlock nix"
echo
echo "Project config (.airlock):"
echo "  image=node"
echo "  command=npm test"
echo
echo "Run airlock in a directory with .airlock to use project settings."
echo
}

menu() {
while true; do

clear

banner

detect_container_runtime

echo
echo "Runtime: $CONTAINER_RUNTIME"
echo

echo "1) Debian"
echo "2) Alpine"
echo "3) Node"
echo "4) Python"
echo "5) Go"
echo "6) Bun"
echo "7) Rust"
echo "8) Java"
echo "9) Ubuntu"
echo "10) Arch"
echo "11) Fedora"
echo "12) Deno"
echo "13) Zig"
echo "14) Nix"
echo "15) Update"
echo "16) Help"
echo "17) Version"
echo "18) Exit"
echo

read -rp "Select option: " choice

case "$choice" in
1) launch_named debian ;;
2) launch_named alpine ;;
3) launch_named node ;;
4) launch_named python ;;
5) launch_named go ;;
6) launch_named bun ;;
7) launch_named rust ;;
8) launch_named java ;;
9) launch_named ubuntu ;;
10) launch_named arch ;;
11) launch_named fedora ;;
12) launch_named deno ;;
13) launch_named zig ;;
14) launch_named nix ;;
15) update_airlock ;;
16) show_help ;;
17) echo "$VERSION" ;;
18) exit 0 ;;
esac

done
}

case "${1:-}" in
"")
if [ -f .airlock ]; then
    launch_from_config
else
    menu
fi
;;
update)
update_airlock
;;
help)
show_help
;;
version)
echo "$VERSION"
;;
debian)
launch_named debian
;;
alpine)
launch_named alpine
;;
node)
launch_named node
;;
python)
launch_named python
;;
go)
launch_named go
;;
bun)
launch_named bun
;;
rust)
launch_named rust
;;
java)
launch_named java
;;
ubuntu)
launch_named ubuntu
;;
arch)
launch_named arch
;;
fedora)
launch_named fedora
;;
deno)
launch_named deno
;;
zig)
launch_named zig
;;
nix)
launch_named nix
;;
*)
echo "Unknown command."
echo "Run: airlock help"
exit 1
;;
esac
