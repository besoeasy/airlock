#!/usr/bin/env bash

set -e

VERSION="0.0.4"

REPO_URL="https://github.com/besoeasy/airlock"
RAW_URL="https://cdn.jsdelivr.net/gh/besoeasy/airlock@main/airlock"
RAW_VER_URL="https://cdn.jsdelivr.net/gh/besoeasy/airlock@main/version.txt"
INSTALL_PATH="/usr/local/bin/airlock"

declare -A IMAGES

IMAGES[debian]="debian:stable"
IMAGES[alpine]="alpine:latest"
IMAGES[node]="node:lts"
IMAGES[python]="python:3"
IMAGES[go]="golang:latest"
IMAGES[bun]="oven/bun:latest"
IMAGES[rust]="rust:latest"
IMAGES[java]="eclipse-temurin:21"
IMAGES[ubuntu]="ubuntu:24.04"
IMAGES[arch]="archlinux:latest"
IMAGES[fedora]="fedora:latest"
IMAGES[deno]="denoland/deno:latest"
IMAGES[zig]="ziglang/zig:latest"

CONFIG_IMAGE=""
CONFIG_COMMAND=""

load_airlock_config() {
CONFIG_IMAGE=""
CONFIG_COMMAND=""

if [ ! -f .airlock ]; then
    return 1
fi

while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [ -z "$line" ] && continue
    case "$line" in
        *=*) ;;
        *) continue ;;
    esac

    key="${line%%=*}"
    value="${line#*=}"
    key="${key#"${key%%[![:space:]]*}"}"
    key="${key%"${key##*[![:space:]]}"}"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"

    case "$key" in
        image) CONFIG_IMAGE="$value" ;;
        command) CONFIG_COMMAND="$value" ;;
    esac
done < .airlock

return 0
}

resolve_image_ref() {
local spec="$1"

if [ -n "${IMAGES[$spec]:-}" ]; then
    echo "${IMAGES[$spec]}"
    return
fi

if [[ "$spec" == *:* || "$spec" == */* ]]; then
    echo "$spec"
    return
fi

echo "Unknown image: $spec"
echo "Run: airlock help"
exit 1
}

resolve_profile() {
local spec="$1"
local key

if [ -n "${IMAGES[$spec]:-}" ]; then
    echo "$spec"
    return
fi

for key in "${!IMAGES[@]}"; do
    if [ "${IMAGES[$key]}" = "$spec" ]; then
        echo "$key"
        return
    fi
done

echo "generic"
}

image_shell() {
case "$1" in
    alpine)
        echo "sh"
        ;;
    *)
        echo "bash"
        ;;
esac
}

image_run_args() {
local profile="$1"
local -n args="$2"

case "$profile" in
    debian|ubuntu|fedora|arch|alpine)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            -e HOME=/workspace
        )
        ;;
    node)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e npm_config_cache=/workspace/.npm-cache
            -e NODE_ENV=development
        )
        ;;
    python)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e PIP_CACHE_DIR=/workspace/.pip-cache
            -e PYTHONDONTWRITEBYTECODE=1
        )
        ;;
    go)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e GOMODCACHE=/workspace/.gomodcache
            -e GOCACHE=/workspace/.gocache
        )
        ;;
    bun)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e BUN_INSTALL_CACHE_DIR=/workspace/.bun-cache
        )
        ;;
    rust)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e CARGO_HOME=/workspace/.cargo
            -e CARGO_TARGET_DIR=/workspace/target
        )
        ;;
    java)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e JAVA_TOOL_OPTIONS=-Duser.home=/workspace
        )
        ;;
    deno)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e DENO_DIR=/workspace/.deno
        )
        ;;
    zig)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
            -e XDG_CACHE_HOME=/workspace/.cache
        )
        ;;
    *)
        args=(
            run -it --rm
            -v "$PWD:/workspace"
            -w /workspace
            --user "$(id -u):$(id -g)"
        )
        ;;
esac
}

banner() {
cat <<'EOF'
    _    _      _            _
   / \  (_)_ __| | ___   ___| | __
  / _ \ | | '__| |/ _ \ / __| |/ /
 / ___ \| | |  | | (_) | (__|   <
/_/   \_\_|_|  |_|\___/ \___|_|\_\

Secure Development Sandbox
EOF
}

detect_container_runtime() {
if command -v docker >/dev/null 2>&1; then
CONTAINER_RUNTIME="docker"
return
fi

if command -v podman >/dev/null 2>&1; then
    CONTAINER_RUNTIME="podman"
    return
fi

echo
echo "Docker or Podman is required."
exit 1

}

launch_image() {
detect_container_runtime

local profile="$1"
local image="$2"
local command="${3:-}"
local shell
local -a run_args

shell=$(image_shell "$profile")
image_run_args "$profile" run_args

if [ -n "$command" ]; then
    "$CONTAINER_RUNTIME" "${run_args[@]}" "$image" "$shell" -c "$command"
else
    "$CONTAINER_RUNTIME" "${run_args[@]}" "$image" "$shell"
fi

}

launch_named() {
local name="$1"

launch_image "$name" "${IMAGES[$name]}"
}

launch_from_config() {
local profile image

load_airlock_config || {
    echo ".airlock not found."
    exit 1
}

if [ -z "$CONFIG_IMAGE" ]; then
    echo ".airlock: image is required."
    exit 1
fi

image=$(resolve_image_ref "$CONFIG_IMAGE")
profile=$(resolve_profile "$CONFIG_IMAGE")
launch_image "$profile" "$image" "$CONFIG_COMMAND"
}

read_version() {
grep '^VERSION=' "$1" | head -n1 | cut -d= -f2- | tr -d '"'
}

install_binary() {
local src="$1"
local dest="$INSTALL_PATH"

if install -m 755 "$src" "$dest" 2>/dev/null; then
    rm -f "$src"
    return 0
fi

if command -v sudo >/dev/null 2>&1; then
    sudo install -m 755 "$src" "$dest"
    rm -f "$src"
    return 0
fi

rm -f "$src"
echo "Failed to install to $dest (permission denied)."
echo "Run: sudo install -m 755 $src $dest"
exit 1
}

download_and_install_airlock() {
local version
local tmp_file

tmp_file=$(mktemp)
curl -fsSL "$RAW_URL" -o "$tmp_file"
chmod +x "$tmp_file"
version=$(read_version "$tmp_file")
install_binary "$tmp_file"
echo "$version"
}

check_for_update() {
local remote_version
local tmp_ver
local installed_path

case "${1:-}" in
    update) return 0 ;;
esac

if [ "${AIRLOCK_SKIP_UPDATE:-}" = "1" ]; then
    return 0
fi

installed_path=$(readlink -f "$INSTALL_PATH" 2>/dev/null || echo "$INSTALL_PATH")
if [ "$(readlink -f "$0" 2>/dev/null || echo "$0")" != "$installed_path" ]; then
    return 0
fi

tmp_ver=$(mktemp)
if ! curl -fsSL --max-time 10 "$RAW_VER_URL" -o "$tmp_ver" 2>/dev/null; then
    echo "Couldn't check for latest version."
    rm -f "$tmp_ver"
    return 0
fi

remote_version=$(tr -d '[:space:]' < "$tmp_ver")
rm -f "$tmp_ver"

if [ -z "$remote_version" ]; then
    echo "Couldn't check for latest version."
    return 0
fi

if [ "$remote_version" = "$VERSION" ]; then
    return 0
fi

echo "Updating Airlock to $remote_version..."
if ! download_and_install_airlock >/dev/null; then
    echo "Couldn't update Airlock."
    return 0
fi

exec "$INSTALL_PATH" "$@"
}

update_airlock() {
local version

echo "Updating Airlock from GitHub..."
version=$(download_and_install_airlock)
echo "Airlock updated to $version."

}

update_airlock_local() {
local version
local tmp_file

if [ ! -f ./airlock ]; then
    echo "./airlock not found. Run this from the Airlock repo."
    exit 1
fi

version=$(read_version ./airlock)
echo "Installing Airlock $version from ./airlock..."

tmp_file=$(mktemp)
cp ./airlock "$tmp_file"
chmod +x "$tmp_file"
install_binary "$tmp_file"

echo "Airlock installed ($version)."

}

show_help() {
echo
echo "Repository:"
echo "$REPO_URL"
echo
echo "Usage:"
echo "  airlock"
echo "  airlock update"
echo "  airlock update --local"
echo "  airlock debian"
echo "  airlock alpine"
echo "  airlock node"
echo "  airlock python"
echo "  airlock go"
echo "  airlock rust"
echo "  airlock java"
echo "  airlock ubuntu"
echo "  airlock arch"
echo "  airlock fedora"
echo "  airlock deno"
echo "  airlock zig"
echo
echo "Project config (.airlock):"
echo "  image=node"
echo "  command=npm test"
echo
echo "Run airlock in a directory with .airlock to use project settings."
echo
}

menu() {
while true; do

clear

banner

detect_container_runtime

echo
echo "Runtime: $CONTAINER_RUNTIME"
echo "Version: $VERSION"
echo

echo "1) Debian"
echo "2) Alpine"
echo "3) Node"
echo "4) Python"
echo "5) Go"
echo "6) Bun"
echo "7) Rust"
echo "8) Java"
echo "9) Ubuntu"
echo "10) Arch"
echo "11) Fedora"
echo "12) Deno"
echo "13) Zig"
echo "14) Exit"
echo

read -rp "Select option: " choice

case "$choice" in
1) launch_named debian ;;
2) launch_named alpine ;;
3) launch_named node ;;
4) launch_named python ;;
5) launch_named go ;;
6) launch_named bun ;;
7) launch_named rust ;;
8) launch_named java ;;
9) launch_named ubuntu ;;
10) launch_named arch ;;
11) launch_named fedora ;;
12) launch_named deno ;;
13) launch_named zig ;;
14) exit 0 ;;
esac

done
}

check_for_update "$@"

case "${1:-}" in
"")
if [ -f .airlock ]; then
    launch_from_config
else
    menu
fi
;;
update)
if [ "${2:-}" = "--local" ] || [ "${2:-}" = "local" ]; then
    update_airlock_local
else
    update_airlock
fi
;;
help)
show_help
;;
version)
echo "$VERSION"
;;
debian)
launch_named debian
;;
alpine)
launch_named alpine
;;
node)
launch_named node
;;
python)
launch_named python
;;
go)
launch_named go
;;
bun)
launch_named bun
;;
rust)
launch_named rust
;;
java)
launch_named java
;;
ubuntu)
launch_named ubuntu
;;
arch)
launch_named arch
;;
fedora)
launch_named fedora
;;
deno)
launch_named deno
;;
zig)
launch_named zig
;;
*)
echo "Unknown command."
echo "Run: airlock help"
exit 1
;;
esac
